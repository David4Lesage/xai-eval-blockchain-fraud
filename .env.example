# ===================================================================
# Environment configuration for xai-eval-blockchain-fraud
# ===================================================================
# Copy this file to .env and fill in your own values.
# The .env file is git-ignored and will never be committed.
# ===================================================================

# --- OpenRouter API (required for Module 4 LLM Agents) ---
# Sign up at https://openrouter.ai to obtain a key.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Model identifiers (optional; defaults use frontier models) ---
# These are resolved against OpenRouter's model catalog.
# See https://openrouter.ai/models for the full list of available IDs.
MODEL_OPUS=anthropic/claude-opus-4.7
MODEL_GEMINI=google/gemini-3.1-pro
MODEL_GPT=openai/gpt-5.4

# --- Inference parameters (optional) ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=800
LLM_RETRIES=3
LLM_RATE_LIMIT_SLEEP=1.0

# --- Compute (optional) ---
# Set to "cuda" to force GPU usage for GNN training, or "cpu" for CPU.
# Leave empty for auto-detection.
TORCH_DEVICE=

# --- Reproducibility ---
RANDOM_SEED=42
